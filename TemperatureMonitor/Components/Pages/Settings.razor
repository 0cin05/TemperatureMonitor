@page "/settings"
@using TemperatureMonitor.Services
@inject IVisibilityService VisibilityService
@implements IDisposable

<div class="toolbar">
    <a class="btn" href="/">← Back</a>
</div>

@if (!VisibilityService.IsReady)
{
    <div class="spinner-wrap">
        <div class="spinner"></div>
        <p class="settings-hint">Detecting sensors…</p>
    </div>
}
else
{
    <div class="settings-section">
        <div class="settings-label-header">Hardware &amp; Sensors</div>
        <div class="settings-list">
            @foreach (var hw in VisibilityService.KnownEntries)
            {
                var k = hw.Key;
                var vis = VisibilityService.IsVisible(k);

                <div class="settings-card @(vis ? "" : "settings-card--off")">
                    <div class="settings-row settings-row--main">
                        <span class="settings-name">@hw.Name</span>
                        <button class="toggle @ToggleOn(vis)" @onclick="() => ToggleEntry(k)">
                            <div class="toggle-thumb"></div>
                        </button>
                    </div>

                    @if (vis && (hw.HasTemp || hw.HasLoad || hw.HasFan))
                    {
                        <div class="settings-sensors">
                            @if (hw.HasTemp)
                            {
                                var s = "temp";
                                <div class="settings-row settings-row--sub">
                                    <span class="settings-sub-label">Temperature</span>
                                    <button class="toggle toggle--sm @ToggleOn(VisibilityService.ShowsSensor(k, s))"
                                            @onclick="() => ToggleSensor(k, s)">
                                        <div class="toggle-thumb"></div>
                                    </button>
                                </div>
                            }
                            @if (hw.HasLoad)
                            {
                                var s = "load";
                                <div class="settings-row settings-row--sub">
                                    <span class="settings-sub-label">Load</span>
                                    <button class="toggle toggle--sm @ToggleOn(VisibilityService.ShowsSensor(k, s))"
                                            @onclick="() => ToggleSensor(k, s)">
                                        <div class="toggle-thumb"></div>
                                    </button>
                                </div>
                            }
                            @if (hw.HasFan)
                            {
                                var s = "fan";
                                <div class="settings-row settings-row--sub">
                                    <span class="settings-sub-label">Fan</span>
                                    <button class="toggle toggle--sm @ToggleOn(VisibilityService.ShowsSensor(k, s))"
                                            @onclick="() => ToggleSensor(k, s)">
                                        <div class="toggle-thumb"></div>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        VisibilityService.Changed += OnChanged;
    }

    private async void OnChanged() => await InvokeAsync(StateHasChanged);

    private void ToggleEntry(string key) =>
        VisibilityService.SetVisible(key, !VisibilityService.IsVisible(key));

    private void ToggleSensor(string key, string sensor) =>
        VisibilityService.SetShowSensor(key, sensor, !VisibilityService.ShowsSensor(key, sensor));

    private static string ToggleOn(bool on) => on ? "toggle--on" : "";

    public void Dispose() => VisibilityService.Changed -= OnChanged;
}