@page "/"
@implements IDisposable
@using TemperaturMonitor.Models
@using TemperaturMonitor.Services
@using TemperaturMonitor.Views
@inject IHardwareService HardwareService
@inject IVisibilityService VisibilityService

<div class="toolbar">
    <button class="btn" @onclick="HardwareService.Reset" disabled="@(!HardwareService.IsReady)">Reset</button>
    <a class="btn" href="settings">Einstellungen</a>
</div>

@if (HardwareService.InitError is not null)
{
    <p style="color:#ef4444">@HardwareService.InitError</p>
}
else if (!HardwareService.IsReady)
{
    <div class="spinner-wrap">
        <div class="spinner"></div>
    </div>
}
else
{
    <div class="grid">
        @foreach (var entry in HardwareService.Entries.Where(e => VisibilityService.IsVisible(e.Key)))
        {
            <Card
                Title="@entry.Name"
                Temp="@entry.Temp"
                MaxTemp="@entry.MaxTemp"
                Points="@entry.Points"
                Load="@entry.Load"
                FanRpm="@entry.FanRpm"
                RamUsedGb="@entry.RamUsedGb"
                RamTotalGb="@entry.RamTotalGb"
                ShowTemp="@(entry.HasTemp && VisibilityService.ShowsSensor(entry.Key, "temp"))"
                ShowLoad="@(entry.HasLoad && VisibilityService.ShowsSensor(entry.Key, "load"))"
                ShowRpm="@(entry.HasFan  && VisibilityService.ShowsSensor(entry.Key, "fan"))" />
        }
    </div>
}

@code {
    protected override void OnInitialized()
    {
        HardwareService.Changed += OnChanged;
        VisibilityService.Changed += OnChanged;
    }

    private async void OnChanged() => await InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        HardwareService.Changed -= OnChanged;
        VisibilityService.Changed -= OnChanged;
    }
}